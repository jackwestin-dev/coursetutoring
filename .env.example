# JW Session Grader Configuration
# Copy this file to .env and fill in your values

# Email Configuration (Gmail example)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Recipients
DIRECTOR_EMAIL=anastasia@jackwestin.com
# Comma-separated list for management email (Session Grader auto-send)
DIRECTOR_EMAILS=anastasia@jackwestin.com,molly@jackwestin.com,carl@jackwestin.com,adam@jackwestin.com
FROM_EMAIL=grader@jackwestin.com

# Fathom.video Integration (optional — for "Sync from Fathom" in CARS Grader)
# Get your API key from: https://fathom.video/settings/integrations
FATHOM_API_KEY=your-fathom-api-key

# Anthropic Claude (required for CARS Session Grader AI grading)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key

# Supabase (for storing session records + 3-day director digest)
# Create a project at https://supabase.com, then run supabase-schema.sql in SQL Editor
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Server
PORT=8080
FLASK_DEBUG=false
