# JW Session Grader Configuration
# Copy this file to .env and fill in your values

# Email Configuration (Gmail example)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Recipients
DIRECTOR_EMAIL=anastasia@jackwestin.com
FROM_EMAIL=grader@jackwestin.com

# Fathom.video Integration (optional)
# Get your API key from: https://fathom.video/settings/integrations
FATHOM_API_KEY=your-fathom-api-key

# Server
PORT=8080
FLASK_DEBUG=false
