{
  "version": 2,
  "builds": [
    {
      "src": "api/grade.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/grade",
      "dest": "/api/grade.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
