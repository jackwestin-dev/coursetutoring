{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "builds": [
    {
      "src": "api/grade.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/fathom.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/claude.py",
      "use": "@vercel/python"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/grade", "dest": "/api/grade.py" },
    { "src": "/api/fathom", "dest": "/api/fathom.py" },
    { "src": "/api/claude", "dest": "/api/claude.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
