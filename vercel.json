{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/grade.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/claude.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/send-email.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/record-session.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/director-digest.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/send-recent-evaluations.py",
      "use": "@vercel/python"
    }
  ],
  "crons": [
    { "path": "/api/director-digest", "schedule": "0 14 */3 * *" }
  ],
  "routes": [
    { "src": "/api/grade", "dest": "/api/grade.py" },
    { "src": "/api/claude", "dest": "/api/claude.py" },
    { "src": "/api/send-email", "dest": "/api/send-email.py" },
    { "src": "/api/record-session", "dest": "/api/record-session.py" },
    { "src": "/api/director-digest", "dest": "/api/director-digest.py" },
    { "src": "/api/send-recent-evaluations", "dest": "/api/send-recent-evaluations.py" },
    { "src": "/api/send-recent-evaluations/", "dest": "/api/send-recent-evaluations.py" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
